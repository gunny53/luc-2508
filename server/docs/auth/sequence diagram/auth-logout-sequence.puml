@startuml Auth - Logout Sequence
!theme plain
skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 2
skinparam roundcorner 16

Auth Auth Logout Sequence: validate request and return the expected response

actor "Client" as C
participant "AuthController" as AC
participant "AuthService" as AS
participant "TokenService" as TS
participant "AuthRepository" as AR
database "PostgreSQL (Prisma)" as DB

C -> AC: POST /auth/logout (cookie refresh_token)
activate AC

AC -> AC: Auth Auth Logout Sequence: validate request and return the expected response
AC -> AS: logout(refreshToken)
activate AS

AS -> TS: verifyRefreshToken(refreshToken)
TS --> AS: ok | error
Auth Auth Logout Sequence: validate request and return the expected response
  AS --> AC: UnauthorizedAccessException (401)
  AC --> C: 401 Unauthorized
  deactivate AS
  deactivate AC
  stop
end

AS -> AR: deleteRefreshToken({ token })
AR -> DB: refreshToken.delete()
DB --> AR: deleted | NotFound
AR --> AS: deleted | error
alt NotFound Prisma
  AS --> AC: RefreshTokenAlreadyUsedException (401)
  AC --> C: 401 Unauthorized
  deactivate AS
  deactivate AC
  stop
end

AS -> AR: updateDevice(deviceId, { isActive: false })
AR -> DB: device.update()
DB --> AR: device
AR --> AS: ok
AS --> AC: Auth Auth Logout Sequence: validate request and return the expected response
deactivate AS

AC --> C: 200 OK + JSON
deactivate AC

@enduml


